.claude/agent-memory/

# Eval results + primary datasets (private working copies — gitignored by design)
Evals/*/results/
Evals/*/inputs/*.jsonl
Evals/memory-consolidation/inputs/*/

# Python bytecode
__pycache__/
*.pyc

# Runtime / local
.DS_Store
*.local
settings.local.json
*.bak
